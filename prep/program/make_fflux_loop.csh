#!/bin/csh
#---------------------------------------------------------------------
# Generate river dataset for each year |
#---------------------------------------------------------------------

set syr=1981
set eyr=2023

#---------------------------------------------------------------------

@ iyr = $syr

while(${iyr} <= ${eyr})

    @ jyr = $iyr + 1

    csh make_fflux.csh ${iyr} 1 1 ${jyr} 1 1
    
    @ iyr++
    
end
