!-------------------------------------------------------------------------
! Define variable |
!-------------------------------------------------------------------------

subroutine define_var_netcdf(ncid,ndim,dim,varid,type,name,long_name,units_name)

  use netcdf
  implicit none

  integer status

  integer,intent(in) :: ncid
  integer,intent(in) :: ndim,dim(ndim)
  integer,intent(inout) :: varid

  character(*),intent(in) :: type
  character(*),intent(in) :: name,long_name,units_name

  if(trim(type) == "int")then
     status=nf90_def_var(ncid,trim(name),nf90_int,dim,varid)
  else if(trim(type) == "real")then
     status=nf90_def_var(ncid,trim(name),nf90_float,dim,varid)
  else if(trim(type) == "dble")then
     status=nf90_def_var(ncid,trim(name),nf90_double,dim,varid)
  end if
  call check_error(status)

  status=nf90_def_var_deflate(ncid,varid,shuffle=1,deflate=1,deflate_level=5)
  call check_error(status)
  
  status=nf90_put_att(ncid,varid,"long_name",trim(long_name))
  call check_error(status)
  
  status=nf90_put_att(ncid,varid,"units",trim(units_name))
  call check_error(status)

end subroutine define_var_netcdf

!----------------------------------------------------------------
! Check netcdf error |
!----------------------------------------------------------------

subroutine check_error(status)

  use netcdf
  implicit none

  integer,intent(in) :: status
 
  if(status /= nf90_noerr) then
    write(*,'(a)') trim(nf90_strerror(status))
    stop "Stopped"
  end if

end subroutine check_error

!-------------------------------------------------------------------
! Make grid NetCDF file |
!-------------------------------------------------------------------

subroutine make_grid_ncfile(im,jm,km)

  use setting, filename => filename_grid
  use netcdf
  implicit none

  !---Parameter
  integer,parameter :: ndim=3
  
  !---Common
  integer status,system
  integer ncid,dimid,varid
  integer dim(ndim)

  !---IN
  integer,intent(in) :: im,jm,km

  !---Remove NetCDF file
  status=system("rm -f "//trim(filename))
  
  !---NF90_CREATE
  status=nf90_create(trim(filename),nf90_netcdf4,ncid)
  call check_error(status)

  !TITLE
  status=nf90_put_att(ncid,NF90_GLOBAL,"title","LORA-QG version 2.0")
  call check_error(status)

  !REERENCE
  status=nf90_put_att(ncid,NF90_GLOBAL,"references","Ohishi et al.")
  
  !---DIMID
  !X
  status=nf90_def_dim(ncid,"im",im,dimid)
  call check_error(status)
  dim(1)=dimid
  
  !Y
  status=nf90_def_dim(ncid,"jm",jm,dimid)
  call check_error(status)
  dim(2)=dimid
  
  !Z
  status=nf90_def_dim(ncid,"km",km,dimid)
  call check_error(status)
  dim(3)=dimid

  !---1D
  !lon
  call define_var_netcdf(ncid,1,dim(1),varid,"real", &
       & "lont","Longitude at temperature, salinity, and SSH grid points","degree E")

  call define_var_netcdf(ncid,1,dim(1),varid,"real", &
       & "lonu","Longitude at zonal velocity grid points","degree E")
  
  call define_var_netcdf(ncid,1,dim(1),varid,"real", &
       & "lonv","Longitude at meridional velocity grid points","degree E")
  
  !lat
  call define_var_netcdf(ncid,1,dim(2),varid,"real", &
       & "latt","Latitude at temperature, salinity, and SSH grid points","degree N")
  
  call define_var_netcdf(ncid,1,dim(2),varid,"real", &
       & "latu","Latitude at zonal velocity grid points","degree N")
  
  call define_var_netcdf(ncid,1,dim(2),varid,"real", &
       & "latv","Latitude at meridional velocity grid points","degree N")

  !---2D
  call define_var_netcdf(ncid,2,dim(1:2),varid,"real", &
       & "maskt","Land-Sea Mask at temperature, salinity, and SSH grid points (1:Sea and 0:Land)","-")

  call define_var_netcdf(ncid,2,dim(1:2),varid,"real", &
       & "masku","Land-Sea Mask at zonal velocity points (1:Sea and 0:Land)","-")

  call define_var_netcdf(ncid,2,dim(1:2),varid,"real", &
       & "maskv","Land-Sea Mask at meridional velocity points (1:Sea and 0:Land)","-")
    
  !---3D
  !depth
  call define_var_netcdf(ncid,3,dim(1:3),varid,"real", &
       & "dept","Depth at temperature and salinity grid points","meter")

  call define_var_netcdf(ncid,3,dim(1:3),varid,"real", &
       & "depu","Depth at zonal velocity grid points","meter")

  call define_var_netcdf(ncid,3,dim(1:3),varid,"real", &
       & "depv","Depth at meridional velocity grid points","meter")

  call define_var_netcdf(ncid,3,dim(1:3),varid,"real", &
       & "depw","Depth at vertical velocity grid points","meter")
  
  !---Close
  status=nf90_enddef(ncid)
  call check_error(status)

  status=nf90_close(ncid)
  call check_error(status)
  
end subroutine make_grid_ncfile

!----------------------------------------------------------------------------
! 2D Ensemble mean/spread NetCDF file |
!----------------------------------------------------------------------------

subroutine make_dat2d_ncfile(ms,varname,long_name,units_name,iyr,imon,iday,im,jm)

  use mod_rmiss
  use netcdf
  implicit none

  !---Parameter
  integer,parameter :: ndim=2
  
  !---Common
  integer status,access,system
  integer ncid,dimid,varid
  integer dim(ndim)

  character(100) dirname,filename
  character(8) yyyymmdd
  character(4) yyyy
  character(2) mm,dd
  
  !---IN
  integer,intent(in) :: iyr,imon,iday
  integer,intent(in) :: im,jm

  character(4) ms
  character(100) varname,long_name,units_name

  !---Filename
  write(yyyy,'(i4.4)') iyr
  write(mm,'(i2.2)') imon
  write(dd,'(i2.2)') iday
  yyyymmdd=yyyy//mm//dd
  dirname="dat/"//yyyymmdd//"/"//trim(ms)
  filename=trim(dirname)//"/"//trim(varname)//yyyymmdd//".nc"
  
  !---Check and Make directory
  status=access(trim(dirname)," ")
  if(status /= 0)then
     status=system("mkdir -p "//trim(dirname))
  end if
  
  status=system("rm -f "//trim(filename))
  
  !---NF90_CREATE
  status=nf90_create(trim(filename),nf90_netcdf4,ncid)
  call check_error(status)

  !TITLE
  status=nf90_put_att(ncid,NF90_GLOBAL,"title","LORA-QG version 2.0")
  call check_error(status)

  !REERENCE
  status=nf90_put_att(ncid,NF90_GLOBAL,"references","Ohishi et al.")
  
  !---DIMID
  !X
  status=nf90_def_dim(ncid,"im",im,dimid)
  call check_error(status)
  dim(1)=dimid
  
  !Y
  status=nf90_def_dim(ncid,"jm",jm,dimid)
  call check_error(status)
  dim(2)=dimid
  
  !---2D
  call define_var_netcdf(ncid,ndim,dim,varid,"real", &
       & trim(varname),trim(long_name),trim(units_name))
  status=nf90_def_var_fill(ncid,varid,0,real(rmiss))
  call check_error(status)
  
  !---Close
  status=nf90_enddef(ncid)
  call check_error(status)

  status=nf90_close(ncid)
  call check_error(status)
  
end subroutine make_dat2d_ncfile

